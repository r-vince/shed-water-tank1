views:
  - title: Water Tanks
    path: water-tanks
    icon: mdi:water
    tank_fill_style: |
      ha-card {
        background: transparent;
        box-shadow: none;
        border: none;
      }

      hui-warning,
      hui-error-card,
      ha-alert,
      .warning,
      .error,
      .state-badge,
      ha-icon {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
      }

      #container, .container {
        width: 48px !important;
        height: 75px !important;
        position: relative !important;
        transform: translate(87px, 3px);
        opacity: 0.82;
        overflow: hidden !important;
        border-radius: 0 0 16px 16px;
      }

      @media (max-width: 900px) {
        #container, .container {
          width: 38px !important;
          height: 70px !important;
          transform: translate(72px, 0px);
          border-radius: 0 0 12px 12px;
        }
      }
    hidden_entities_style: |
      ha-card {
        background: transparent !important;
        box-shadow: none !important;
        border: none !important;
        min-height: 0 !important;
        height: 0 !important;
        overflow: hidden !important;
        padding: 0 !important;
        margin: 0 !important;
      }
      .card-content {
        display: none !important;
        padding: 0 !important;
        margin: 0 !important;
      }
    tank_percent_style:
      left: 50%
      top: 32%
      transform: translate(-50%, -50%)
      color: white
      font-size: 16px
      font-weight: bold
      text-shadow: 0 0 8px rgba(0,0,0,0.95)
    tank_card_style: |
      ha-card {
        background: #0b1117;
        border-radius: 22px;
        padding: 10px 10px 4px 10px;
      }
    title_card_style: |
      ha-card {
        background: #0b1117;
        border-radius: 22px;
        padding: 8px 0;
      }
      ha-markdown h1 {
        text-align: center !important;
        width: 100%;
        display: block;
        font-size: 44px !important;
        font-weight: 800 !important;
        line-height: 1.1 !important;
        margin: 0 !important;
      }
      ha-markdown {
        padding: 0 !important;
        text-align: center !important;
      }
      .card-content {
        text-align: center !important;
      }
    tank_name_card_style: |
      ha-card {
        background: #0b1117;
        border-radius: 22px;
        padding: 8px 0;
      }
      ha-markdown h2 {
        text-align: center !important;
        font-size: 32px !important;
        font-weight: 700 !important;
        margin: 0 !important;
        line-height: 1.2 !important;
      }
      ha-markdown {
        text-align: center !important;
        padding: 0 !important;
      }
      .card-content {
        text-align: center !important;
      }
    history_card_style: |
      ha-card {
        background: #0b1117;
        border-radius: 22px;
        padding: 10px;
      }
    status_card_style: |
      ha-card {
        background: #0b1117;
        border-radius: 22px;
        padding: 10px;
      }
    cards:
      - type: vertical-stack
        cards:
          - type: markdown
            content: |
              # Water Tanks
            card_mod:
              style: |
